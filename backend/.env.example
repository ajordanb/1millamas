# SMTP (Resend)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=resend
SMTP_PASSWORD=re_your_api_key_here
EMAILS_FROM_NAME="Your Name"
EMAILS_FROM_EMAIL=no-reply@yourdomain.com

# Admin notifications + who can log into the admin dashboard.
# Pipe-separate multiple admins, e.g. "you@example.com|cofounder@example.com"
ADMIN_USERS="you@example.com"

# Database
DB_CONN_STR=mongodb://localhost:27017/
DB_NAME=una_milla_mas

# App
APP_NAME="Una Milla Mas"
# Used to build absolute URLs for locally-stored uploads.
APP_DOMAIN=http://localhost:5151
# Comma-separated allowed CORS origins (the frontend dev server runs on :3000)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# File storage for donation screenshots.
#   STORAGE_BACKEND=local  -> saved under ./uploads and served at /uploads (dev default)
#   STORAGE_BACKEND=gcs    -> uploaded to a Google Cloud Storage bucket
STORAGE_BACKEND=local
UPLOAD_DIR=uploads
GCS_BUCKET=
# Optional: path to a service-account JSON key. If empty, uses Application Default Credentials.
GCS_CREDENTIALS_FILE=
# Optional override for the public URL base (defaults to https://storage.googleapis.com/<bucket>)
PUBLIC_STORAGE_BASE_URL=

# Challenge links sent in the registration confirmation email (leave blank until ready).
# Challenge Hound challenges (distance tracking), one per discipline:
CHALLENGE_RUN_URL=
CHALLENGE_BIKE_URL=
# Access code participants use to join the Challenge Hound challenge:
CHALLENGE_JOIN_CODE=1millamas
# Strava club for community / questions (not used for tracking):
STRAVA_CLUB_URL=

# Security (change all of these in production)
SECRET_KEY=change_me
AUTHJWT_REFRESH_KEY=change_me
USER_DEFAULT_PASSWORD=change_me

# Google OAuth (Web Client ID from Google Cloud Console; used as the JWT aud claim)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Apple Sign in (Services ID / client ID; used as the JWT aud claim)
APPLE_CLIENT_ID=com.yourdomain.yourapp
