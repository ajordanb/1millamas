# Backend API base URL
VITE_API_URL=http://localhost:5151

# Google OAuth Web Client ID (enables "Continue with Google"). Leave blank to hide it.
VITE_GOOGLE_CLIENT_ID=

# Fundraiser link shown on the rules / registration pages
VITE_GOFUNDME_URL=

# Challenge Hound challenge links (distance tracking), one per discipline
VITE_CHALLENGE_RUN_URL=
VITE_CHALLENGE_BIKE_URL=
# Access code revealed after registration to join the Challenge Hound challenge
VITE_CHALLENGE_JOIN_CODE=1millamas

# Strava club for community / questions (not used for tracking)
VITE_STRAVA_CLUB_URL=
