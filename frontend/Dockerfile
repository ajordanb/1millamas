FROM node:22-alpine AS builder
WORKDIR /usr/src/app
COPY package*.json ./
RUN npm install
COPY . .
ARG VITE_API_URL
ARG VITE_GOFUNDME_URL
ARG VITE_CHALLENGE_RUN_URL
ARG VITE_CHALLENGE_BIKE_URL
ARG VITE_CHALLENGE_JOIN_CODE
ARG VITE_STRAVA_CLUB_URL
ENV VITE_API_URL=$VITE_API_URL \
    VITE_GOFUNDME_URL=$VITE_GOFUNDME_URL \
    VITE_CHALLENGE_RUN_URL=$VITE_CHALLENGE_RUN_URL \
    VITE_CHALLENGE_BIKE_URL=$VITE_CHALLENGE_BIKE_URL \
    VITE_CHALLENGE_JOIN_CODE=$VITE_CHALLENGE_JOIN_CODE \
    VITE_STRAVA_CLUB_URL=$VITE_STRAVA_CLUB_URL
RUN npm run build


FROM socialengine/nginx-spa:latest AS runner
COPY --from=builder /usr/src/app/dist /app
EXPOSE 80
CMD ["nginx"]
